# 每个 agent 的独立 runtime 工作目录根路径（会自动创建 reasoning/act/parsing 子目录）
# PIKAQIU_RUNTIME_WORKSPACE_ROOT=.runtime_workspaces

# 模型名：优先级 ANTHROPIC_MODEL > CLAUDE_AGENT_MODEL > DEEPSEEK_MODEL
ANTHROPIC_MODEL=deepseek-reasoner
CLAUDE_AGENT_MODEL=
DEEPSEEK_MODEL=

# 认证方式二选一：
# 1) ANTHROPIC_API_KEY（直连官方 Anthropic）
# 2) ANTHROPIC_AUTH_TOKEN + ANTHROPIC_BASE_URL（兼容网关）
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# 兼容旧字段（可选）：若填写 DEEPSEEK_API_KEY/DEEPSEEK_BASE_URL，也会自动映射到上面两项。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
