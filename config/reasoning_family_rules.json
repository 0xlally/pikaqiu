    {
      "rule_id": "object-id-selectors",
      "family_id": "object_access_control",
      "weight": 4,
      "keywords": ["user_id", "order_id", "file_id", "tenant_id", "{user_id}", "{order_id}", "{file_id}", "{tenant_id}"],
      "synonyms": ["object id", "resource id", "detail object", "specified object"],
      "source_fields": ["discovered_endpoints", "discovered_fields", "discovered_objects", "discovered_actions"],
      "reason": "controllable object selector or target object"
    },
    {
      "rule_id": "object-detail-download",
      "family_id": "object_access_control",
      "weight": 2,
      "keywords": ["detail", "details", "download", "profile", "record"],
      "synonyms": ["view object", "download object", "view details"],
      "source_fields": ["discovered_pages", "discovered_endpoints", "discovered_actions"],
      "reason": "feature exposes object-specific view or retrieval behavior"
    },
    {
      "rule_id": "property-editable-fields",
      "family_id": "property_access_control",
